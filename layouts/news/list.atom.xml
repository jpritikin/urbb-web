{{- $all := sort (where .Site.RegularPages "Section" "news") "Date" "desc" -}}
{{- $pages := slice -}}
{{- range $all }}{{- if not (.Date.After now) }}{{- $pages = $pages | append . }}{{- end }}{{- end -}}<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ .Site.Title }} — News</title>
  <link href="{{ .Permalink }}atom.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ .Permalink }}" rel="alternate" type="text/html"/>
  <updated>{{ if $pages }}{{ (index $pages 0).Date.Format "2006-01-02T15:04:05Z07:00" }}{{ else }}{{ now.Format "2006-01-02T15:04:05Z07:00" }}{{ end }}</updated>
  <id>{{ .Permalink }}</id>
  <author><name>{{ .Site.Title }}</name></author>
  {{- range $pages }}
  <entry>
    <title>{{ .Title }}</title>
    <link href="{{ .Permalink }}" rel="alternate" type="text/html"/>
    <id>{{ .Permalink }}</id>
    <published>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</published>
    <updated>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</updated>
    <content type="html"><![CDATA[{{ .Content }}]]></content>
  </entry>
  {{- end }}
</feed>
