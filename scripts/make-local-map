#!/usr/bin/env python3
"""Generate regional map images with bookstore pins from bookstores.yaml.

Reads static/data/bookstores.yaml, groups stores by region, fetches
OpenStreetMap tiles for each region, composites them into images, draws
pin markers, and writes:
  - static/images/local-bookstores-map-{region}.webp  (per-region map images)
  - static/data/bookstores-map.json                   (region + pin data for JS)
"""

import json
import math
import os
import sys
from collections import defaultdict
from io import BytesIO
from pathlib import Path

import requests
from PIL import Image, ImageDraw

ROOT = Path(__file__).resolve().parent.parent
YAML_PATH = ROOT / "static" / "data" / "bookstores.yaml"
IMG_DIR = ROOT / "static" / "images"
JSON_OUT = ROOT / "static" / "data" / "bookstores-map.json"

TILE_SIZE = 256
TILE_URL = "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
HEADERS = {"User-Agent": "urbb-web-map-generator/1.0 (jpritikin73@gmail.com)"}

PAD_FACTOR = 0.3
PIN_RADIUS = 4
PIN_COLOR = (220, 38, 38)
PIN_BORDER = (255, 255, 255)
MAX_DIMENSION = 1200

REGION_LABELS = {
    "north": "🌲 Cottage Grove / Roseburg",
    "central": "🌿 Rogue Valley",
}


def parse_yaml_simple(path):
    stores = []
    current = None
    with open(path) as f:
        for line in f:
            line = line.rstrip()
            if line.startswith("- "):
                if current:
                    stores.append(current)
                current = {}
                line = line[2:]
            if current is None:
                continue
            line = line.lstrip()
            if ":" in line:
                key, _, val = line.partition(":")
                val = val.strip().strip('"').strip("'")
                if key in ("lat", "lon"):
                    val = float(val)
                current[key.strip()] = val
    if current:
        stores.append(current)
    return stores


def lat_lon_to_tile(lat, lon, zoom):
    n = 2 ** zoom
    x = (lon + 180) / 360 * n
    lat_rad = math.radians(lat)
    y = (1 - math.log(math.tan(lat_rad) + 1 / math.cos(lat_rad)) / math.pi) / 2 * n
    return x, y


def fetch_tile(z, x, y):
    url = TILE_URL.format(z=z, x=x, y=y)
    resp = requests.get(url, headers=HEADERS, timeout=10)
    resp.raise_for_status()
    return Image.open(BytesIO(resp.content)).convert("RGBA")


def find_zoom(stores):
    lats = [s["lat"] for s in stores]
    lons = [s["lon"] for s in stores]
    min_lat, max_lat = min(lats), max(lats)
    min_lon, max_lon = min(lons), max(lons)

    lat_span = max(max_lat - min_lat, 0.15)
    lon_span = max(max_lon - min_lon, 0.15)
    mid_lat = (min_lat + max_lat) / 2
    mid_lon = (min_lon + max_lon) / 2
    min_lat = mid_lat - lat_span / 2
    max_lat = mid_lat + lat_span / 2
    min_lon = mid_lon - lon_span / 2
    max_lon = mid_lon + lon_span / 2
    min_lon_span = lat_span * 1.0
    if lon_span < min_lon_span:
        extra = (min_lon_span - lon_span) / 2
        min_lon -= extra
        max_lon += extra
        lon_span = max_lon - min_lon
    lat_pad = lat_span * PAD_FACTOR
    lon_pad = lon_span * PAD_FACTOR
    min_lat -= lat_pad
    max_lat += lat_pad
    min_lon -= lon_pad
    max_lon += lon_pad

    for zoom in range(15, 4, -1):
        x1, y1 = lat_lon_to_tile(max_lat, min_lon, zoom)
        x2, y2 = lat_lon_to_tile(min_lat, max_lon, zoom)
        pixel_w = abs(x2 - x1) * TILE_SIZE
        pixel_h = abs(y2 - y1) * TILE_SIZE
        if pixel_w <= MAX_DIMENSION and pixel_h <= MAX_DIMENSION:
            return zoom, (min_lat, max_lat, min_lon, max_lon)
    return 6, (min_lat, max_lat, min_lon, max_lon)


def build_region_map(region_id, stores):
    print(f"\n--- Region: {region_id} ({len(stores)} stores) ---")
    zoom, (min_lat, max_lat, min_lon, max_lon) = find_zoom(stores)
    print(f"Using zoom level {zoom}")

    tl_x, tl_y = lat_lon_to_tile(max_lat, min_lon, zoom)
    br_x, br_y = lat_lon_to_tile(min_lat, max_lon, zoom)

    tile_x_start = int(math.floor(tl_x))
    tile_x_end = int(math.floor(br_x))
    tile_y_start = int(math.floor(tl_y))
    tile_y_end = int(math.floor(br_y))

    img_w = (tile_x_end - tile_x_start + 1) * TILE_SIZE
    img_h = (tile_y_end - tile_y_start + 1) * TILE_SIZE
    composite = Image.new("RGBA", (img_w, img_h))

    total_tiles = (tile_x_end - tile_x_start + 1) * (tile_y_end - tile_y_start + 1)
    fetched = 0
    for tx in range(tile_x_start, tile_x_end + 1):
        for ty in range(tile_y_start, tile_y_end + 1):
            tile = fetch_tile(zoom, tx, ty)
            px = (tx - tile_x_start) * TILE_SIZE
            py = (ty - tile_y_start) * TILE_SIZE
            composite.paste(tile, (px, py))
            fetched += 1
            print(f"  Fetched tile {fetched}/{total_tiles}", end="\r")
    print()

    crop_left = int((tl_x - tile_x_start) * TILE_SIZE)
    crop_top = int((tl_y - tile_y_start) * TILE_SIZE)
    crop_right = int((br_x - tile_x_start) * TILE_SIZE)
    crop_bottom = int((br_y - tile_y_start) * TILE_SIZE)
    composite = composite.crop((crop_left, crop_top, crop_right, crop_bottom))

    draw = ImageDraw.Draw(composite)
    pin_data = []

    for store in stores:
        sx, sy = lat_lon_to_tile(store["lat"], store["lon"], zoom)
        px = int((sx - tl_x) * TILE_SIZE)
        py = int((sy - tl_y) * TILE_SIZE)

        r = PIN_RADIUS
        draw.ellipse([px - r, py - r, px + r, py + r], fill=PIN_COLOR, outline=PIN_BORDER, width=2)

        pin_data.append({
            "name": store["name"],
            "address": store["address"],
            "region": region_id,
            "x": px,
            "y": py,
        })
        print(f"  Pin: {store['name']} at ({px}, {py})")

    final_w = composite.width
    final_h = composite.height
    print(f"Map size: {final_w}x{final_h}")

    img_path = IMG_DIR / f"local-bookstores-map-{region_id}.webp"
    IMG_DIR.mkdir(parents=True, exist_ok=True)
    composite.convert("RGB").save(img_path, "webp", quality=85)
    print(f"Wrote {img_path}")

    return {
        "id": region_id,
        "label": REGION_LABELS.get(region_id, region_id),
        "image": f"/images/local-bookstores-map-{region_id}.webp",
        "width": final_w,
        "height": final_h,
    }, pin_data


if __name__ == "__main__":
    stores = parse_yaml_simple(YAML_PATH)
    if not stores:
        print("No bookstores found!", file=sys.stderr)
        sys.exit(1)
    print(f"Found {len(stores)} bookstores")

    by_region = defaultdict(list)
    for s in stores:
        by_region[s.get("region", "default")].append(s)

    regions = []
    all_pins = []
    for region_id in sorted(by_region):
        region_info, pins = build_region_map(region_id, by_region[region_id])
        regions.append(region_info)
        all_pins.extend(pins)

    map_json = {"regions": regions, "pins": all_pins}
    with open(JSON_OUT, "w") as f:
        json.dump(map_json, f, indent=2)
    print(f"\nWrote {JSON_OUT}")
    print("\n© OpenStreetMap contributors — https://www.openstreetmap.org/copyright")
